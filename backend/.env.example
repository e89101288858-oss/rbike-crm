# Server
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rbike"

# Auth
JWT_SECRET="change_this_to_long_random_secret"

# CORS (comma-separated list for frontend URLs)
# Example: CORS_ORIGIN="http://localhost:3000,http://YOUR_SERVER_IP:3000"
CORS_ORIGIN="http://localhost:3000"

# Initial owner seed (optional)
OWNER_EMAIL="owner@example.com"
OWNER_PASSWORD="change_me"

# YooKassa (SaaS billing)
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_RETURN_URL="https://app.rbcrm.ru/settings"
YOOKASSA_VAT_CODE="1"

# App URL for links in emails
APP_URL="https://app.rbcrm.ru"

# SMTP (Mail.ru business mail example)
SMTP_HOST="smtp.mail.ru"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="no-reply@rbcrm.ru"
SMTP_PASS=""
SMTP_FROM="rbCRM <no-reply@rbcrm.ru>"
